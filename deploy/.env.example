# Copy to `.env` beside docker-compose.yml. These fill ${VAR} references in your config
# and pin image versions. Never commit the real .env.

# Timezone for logs and timeline labels
TZ=UTC

# Pin a specific published image instead of :latest (e.g. VIDETTE_TAG=0.1.0)
# VIDETTE_TAG=latest

# Direct WebRTC live view (optional): your host's LAN address for ICE, e.g. 192.168.1.20:8555.
# Without it live view still works — the player falls back to MSE over WebSocket.
# VIDETTE_WEBRTC_CANDIDATES=192.168.1.20:8555

# Secrets referenced from your camera/notification config as ${VAR}
# CAM_PASSWORD=change-me
# EUFY_RTSP_PASSWORD=change-me
# VIDETTE_WEBHOOK_SECRET=change-me
# TG_BOT_TOKEN=
# TG_CHAT_ID=
